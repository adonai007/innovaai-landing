---
import Button from './Button.astro';

interface Props {
  product: {
    name: string;
    tagline: string;
    description: string;
    pills: string[];
    color: 'dicta' | 'diariomed';
    cta: string;
    ctaHref: string;
  };
  reversed?: boolean;
}

const { product, reversed = false } = Astro.props;
const colorMap = {
  dicta: { text: 'text-dicta', bg: 'bg-dicta/10', border: 'border-dicta/20', glow: 'rgba(52,211,153,0.15)' },
  diariomed: { text: 'text-diariomed', bg: 'bg-diariomed/10', border: 'border-diariomed/20', glow: 'rgba(16,185,129,0.15)' },
};
const colors = colorMap[product.color];
---

<div class={`grid lg:grid-cols-2 gap-12 lg:gap-16 items-center ${reversed ? 'lg:direction-rtl' : ''}`} data-animate="fade-up">
  <!-- Mockup -->
  <div class={`relative ${reversed ? 'lg:order-2' : ''}`}>
    <div class="relative rounded-2xl overflow-hidden glass p-8 aspect-[4/3] flex items-center justify-center" style={`box-shadow: 0 0 60px ${colors.glow}`}>
      <!-- Abstract UI Mockup -->
      <div class="w-full max-w-sm space-y-4">
        <div class="flex items-center gap-3 mb-6">
          <div class={`w-3 h-3 rounded-full ${colors.bg} ${colors.text}`} style="box-shadow: 0 0 8px currentColor"></div>
          <div class="h-2 w-24 rounded-full bg-white/10"></div>
          <div class="ml-auto h-2 w-16 rounded-full bg-white/5"></div>
        </div>
        <div class="h-3 w-full rounded-full bg-white/8"></div>
        <div class="h-3 w-4/5 rounded-full bg-white/6"></div>
        <div class="h-3 w-3/5 rounded-full bg-white/4"></div>
        <div class="mt-6 flex gap-3">
          <div class={`h-8 w-20 rounded-lg ${colors.bg}`}></div>
          <div class="h-8 w-20 rounded-lg bg-white/5"></div>
        </div>
        <div class="mt-4 h-24 rounded-xl bg-white/[0.03] border border-white/5 p-4">
          <div class="h-2 w-full rounded bg-white/8 mb-2"></div>
          <div class="h-2 w-3/4 rounded bg-white/5 mb-2"></div>
          <div class="h-2 w-1/2 rounded bg-white/3"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class={`${reversed ? 'lg:order-1 lg:text-right' : ''}`} style="direction: ltr;">
    <span class={`inline-block px-3 py-1 rounded-full text-xs font-bold tracking-wider uppercase ${colors.bg} ${colors.text} border ${colors.border} mb-4`}>
      {product.name}
    </span>
    <h3 class="text-[length:var(--text-3xl)] font-bold mb-4">{product.tagline}</h3>
    <p class="text-text-secondary text-lg leading-relaxed mb-6">{product.description}</p>

    <!-- Pills -->
    <div class={`flex flex-wrap gap-3 mb-8 ${reversed ? 'lg:justify-end' : ''}`}>
      {product.pills.map(pill => (
        <span class="px-3 py-1.5 rounded-lg text-sm font-medium bg-white/5 text-text-secondary border border-white/10">
          {pill}
        </span>
      ))}
    </div>

    <Button variant="primary" href={product.ctaHref}>{product.cta}</Button>
  </div>
</div>
