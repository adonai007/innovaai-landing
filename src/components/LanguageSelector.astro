---
interface Props {
  currentLang: 'es' | 'en';
}

const { currentLang } = Astro.props;
const altLang = currentLang === 'es' ? 'en' : 'es';
const altHref = `/${altLang}/`;
const ariaLabel =
  altLang === 'en' ? 'Switch to English' : 'Cambiar a español';
---

<a href={altHref} class="language-switch" aria-label={ariaLabel}>
  <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
    <circle cx="12" cy="12" r="9" />
    <path d="M3 12h18M12 3c2.7 2.6 4 5.6 4 9s-1.3 6.4-4 9c-2.7-2.6-4-5.6-4-9s1.3-6.4 4-9Z" />
  </svg>
  {altLang.toUpperCase()}
</a>

<style>
  .language-switch {
    display: inline-flex;
    min-height: 40px;
    align-items: center;
    gap: 0.4rem;
    padding: 0 0.75rem;
    border: 1px solid rgba(148, 163, 184, 0.15);
    border-radius: 0.7rem;
    color: var(--color-text-secondary);
    background: rgba(255, 255, 255, 0.025);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    transition: color 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .language-switch:hover {
    color: var(--color-text-primary);
    border-color: rgba(34, 197, 94, 0.35);
    background: rgba(34, 197, 94, 0.07);
  }

  svg {
    width: 0.95rem;
    height: 0.95rem;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
</style>
