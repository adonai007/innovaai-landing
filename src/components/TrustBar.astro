---
interface Props {
  trust: {
    text: string;
    industries: string[];
    closing: string;
  };
}

const { trust } = Astro.props;
---

<section class="trust-strip" aria-label={trust.text}>
  <div class="trust-inner">
    <span class="trust-label">{trust.text}</span>
    <div class="trust-industries">
      {trust.industries.map((industry) => (
        <>
          <span>{industry}</span>
          <i aria-hidden="true"></i>
        </>
      ))}
    </div>
    <span class="trust-closing">{trust.closing}</span>
  </div>
</section>

<style>
  .trust-strip {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(148, 163, 184, 0.1);
    background: rgba(7, 14, 25, 0.72);
  }

  .trust-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    width: min(100% - 2rem, 1380px);
    min-height: 78px;
    margin: 0 auto;
  }

  .trust-label,
  .trust-closing {
    flex: none;
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
    font-size: 0.63rem;
    letter-spacing: 0.14em;
    white-space: nowrap;
  }

  .trust-closing {
    color: var(--color-primary-light);
  }

  .trust-industries {
    display: flex;
    min-width: 0;
    flex: 1;
    align-items: center;
    justify-content: center;
    gap: clamp(1rem, 2.3vw, 2.2rem);
    color: var(--color-text-secondary);
    font-size: 0.8rem;
    white-space: nowrap;
  }

  .trust-industries i {
    width: 0.24rem;
    height: 0.24rem;
    border-radius: 50%;
    background: var(--color-primary);
  }

  @media (max-width: 980px) {
    .trust-inner {
      overflow: hidden;
    }

    .trust-industries {
      justify-content: flex-start;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .trust-industries::-webkit-scrollbar {
      display: none;
    }

    .trust-closing {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .trust-inner {
      display: block;
      width: 100%;
      padding: 1.15rem 0;
    }

    .trust-label {
      display: block;
      padding: 0 1rem 0.8rem;
    }

    .trust-industries {
      padding: 0 1rem;
    }
  }
</style>
