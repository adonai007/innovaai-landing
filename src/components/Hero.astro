---
import Button from './Button.astro';

interface Props {
  hero: {
    eyebrow: string;
    headlineBefore: string;
    headlineAccent: string;
    headlineAfter: string;
    subheadline: string;
    ctaPrimary: string;
    ctaPrimaryHref: string;
    ctaSecondary: string;
    ctaSecondaryHref: string;
    note: string;
    metrics: { value: string; label: string }[];
    visual: {
      eyebrow: string;
      title: string;
      description: string;
      dictaLabel: string;
      dictaAlt: string;
      dentimedLabel: string;
      dentimedAlt: string;
      status: string;
    };
  };
}

const { hero } = Astro.props;
---

<section id="hero" class="hero-section">
  <div class="hero-atmosphere" aria-hidden="true"></div>

  <div class="hero-inner">
    <div class="hero-copy">
      <div class="eyebrow" data-animate="hero-sub">
        <span class="eyebrow-dot"></span>
        {hero.eyebrow}
      </div>

      <h1 data-animate="hero-headline">
        <span class="hero-word">{hero.headlineBefore}</span>
        <span class="hero-word gradient-text">{hero.headlineAccent}</span>
        <span class="hero-word">{hero.headlineAfter}</span>
      </h1>

      <p class="hero-subheadline" data-animate="hero-sub">
        {hero.subheadline}
      </p>

      <div class="hero-actions" data-animate="hero-ctas">
        <Button variant="primary" size="lg" href={hero.ctaPrimaryHref}>
          <span>{hero.ctaPrimary}</span>
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </Button>
        <Button variant="secondary" size="lg" href={hero.ctaSecondaryHref}>
          {hero.ctaSecondary}
        </Button>
      </div>

      <p class="hero-note" data-animate="hero-badges">{hero.note}</p>

      <div class="hero-metrics" data-animate="hero-badges">
        {hero.metrics.map((metric) => (
          <div class="hero-metric">
            <strong>{metric.value}</strong>
            <span>{metric.label}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="hero-visual" data-animate="hero-sub">
      <div class="visual-heading">
        <div>
          <span class="visual-eyebrow">{hero.visual.eyebrow}</span>
          <h2>{hero.visual.title}</h2>
          <p>{hero.visual.description}</p>
        </div>
        <span class="visual-status">
          <span></span>
          {hero.visual.status}
        </span>
      </div>

      <div class="product-stage">
        <figure class="dicta-preview">
          <div class="preview-bar" aria-hidden="true">
            <span></span><span></span><span></span>
            <small>{hero.visual.dictaLabel}</small>
          </div>
          <img
            src="/images/landing/dicta-product.png"
            alt={hero.visual.dictaAlt}
            width="1200"
            height="800"
            fetchpriority="high"
          />
        </figure>

        <figure class="dentimed-preview">
          <div class="phone-speaker" aria-hidden="true"></div>
          <img
            src="/images/landing/dentimed-grabacion.png"
            alt={hero.visual.dentimedAlt}
            width="412"
            height="915"
            fetchpriority="high"
          />
          <figcaption>{hero.visual.dentimedLabel}</figcaption>
        </figure>

        <div class="stage-orbit stage-orbit-one" aria-hidden="true"></div>
        <div class="stage-orbit stage-orbit-two" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    overflow: hidden;
    min-height: 100svh;
    padding: clamp(8.5rem, 13vw, 11rem) 0 clamp(4.5rem, 7vw, 7rem);
    border-bottom: 1px solid rgba(148, 163, 184, 0.11);
  }

  .hero-section::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(148, 163, 184, 0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.045) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: linear-gradient(to bottom, black 0%, transparent 88%);
  }

  .hero-atmosphere {
    position: absolute;
    inset: -20%;
    pointer-events: none;
    background:
      radial-gradient(circle at 20% 18%, rgba(34, 197, 94, 0.16), transparent 26%),
      radial-gradient(circle at 78% 28%, rgba(59, 130, 246, 0.13), transparent 28%),
      radial-gradient(circle at 54% 80%, rgba(6, 182, 212, 0.07), transparent 24%);
    filter: blur(18px);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(480px, 0.92fr);
    gap: clamp(3rem, 6vw, 6.5rem);
    align-items: center;
    width: min(100% - 2rem, 1380px);
    margin: 0 auto;
  }

  .hero-copy {
    max-width: 760px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 1.6rem;
    padding: 0.55rem 0.8rem;
    border: 1px solid rgba(34, 197, 94, 0.24);
    border-radius: 999px;
    color: var(--color-primary-light);
    background: rgba(34, 197, 94, 0.07);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
  }

  .eyebrow-dot {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--color-primary-light);
    box-shadow: 0 0 14px var(--color-primary);
  }

  h1 {
    max-width: 820px;
    margin: 0;
    font-size: clamp(3.3rem, 6.6vw, 6.9rem);
    line-height: 0.94;
    letter-spacing: -0.065em;
    text-wrap: balance;
  }

  .hero-word {
    display: block;
    opacity: 0;
    transform: translateY(28px);
  }

  .hero-subheadline {
    max-width: 670px;
    margin: 2rem 0 0;
    color: var(--color-text-secondary);
    font-size: clamp(1.05rem, 1.3vw, 1.28rem);
    line-height: 1.68;
    opacity: 0;
    transform: translateY(16px);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 2.1rem;
    opacity: 0;
    transform: translateY(16px);
  }

  .hero-actions svg {
    width: 1.1rem;
    height: 1.1rem;
    margin-left: 0.65rem;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: transform 180ms ease;
  }

  .hero-actions a:hover svg {
    transform: translateX(3px);
  }

  .hero-note {
    margin: 0.95rem 0 0;
    color: var(--color-text-tertiary);
    font-size: 0.8rem;
    opacity: 0;
  }

  .hero-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
    margin-top: clamp(2.8rem, 6vw, 4.7rem);
    padding-top: 1.4rem;
    border-top: 1px solid rgba(148, 163, 184, 0.14);
    opacity: 0;
  }

  .hero-metric {
    min-width: 0;
  }

  .hero-metric strong {
    display: block;
    color: var(--color-primary-light);
    font-family: var(--font-heading);
    font-size: clamp(1.45rem, 2vw, 2.05rem);
    letter-spacing: -0.04em;
  }

  .hero-metric span {
    display: block;
    max-width: 12rem;
    margin-top: 0.25rem;
    color: var(--color-text-tertiary);
    font-size: 0.75rem;
    line-height: 1.45;
  }

  .hero-visual {
    position: relative;
    min-width: 0;
    padding: 1.2rem;
    border: 1px solid rgba(148, 163, 184, 0.16);
    border-radius: 2rem;
    background:
      linear-gradient(145deg, rgba(17, 30, 50, 0.92), rgba(6, 13, 24, 0.9)),
      var(--color-bg-secondary);
    box-shadow:
      0 35px 100px rgba(0, 0, 0, 0.42),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    opacity: 0;
    transform: translateY(22px);
  }

  .hero-visual::before {
    content: '';
    position: absolute;
    inset: -1px;
    z-index: -1;
    border-radius: inherit;
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.22), transparent 40%, rgba(59, 130, 246, 0.2));
    filter: blur(22px);
    opacity: 0.55;
  }

  .visual-heading {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    justify-content: space-between;
    padding: 0.65rem 0.65rem 1.2rem;
  }

  .visual-eyebrow {
    color: var(--color-primary-light);
    font-family: var(--font-mono);
    font-size: 0.63rem;
    letter-spacing: 0.16em;
  }

  .visual-heading h2 {
    max-width: 20rem;
    margin: 0.55rem 0 0;
    font-size: clamp(1.55rem, 2.2vw, 2.2rem);
    line-height: 1.02;
    letter-spacing: -0.045em;
  }

  .visual-heading p {
    max-width: 25rem;
    margin: 0.75rem 0 0;
    color: var(--color-text-tertiary);
    font-size: 0.82rem;
    line-height: 1.55;
  }

  .visual-status {
    display: inline-flex;
    flex: none;
    align-items: center;
    gap: 0.45rem;
    padding: 0.52rem 0.65rem;
    border: 1px solid rgba(34, 197, 94, 0.18);
    border-radius: 999px;
    color: var(--color-text-secondary);
    background: rgba(34, 197, 94, 0.06);
    font-size: 0.64rem;
    white-space: nowrap;
  }

  .visual-status span {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--color-primary-light);
    box-shadow: 0 0 12px var(--color-primary);
  }

  .product-stage {
    position: relative;
    min-height: 460px;
    overflow: hidden;
    border: 1px solid rgba(148, 163, 184, 0.12);
    border-radius: 1.35rem;
    background:
      radial-gradient(circle at 80% 16%, rgba(59, 130, 246, 0.16), transparent 30%),
      radial-gradient(circle at 24% 70%, rgba(34, 197, 94, 0.14), transparent 34%),
      #07101d;
  }

  .product-stage::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(148, 163, 184, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.04) 1px, transparent 1px);
    background-size: 42px 42px;
  }

  .dicta-preview {
    position: absolute;
    top: 3rem;
    left: 1.4rem;
    width: 79%;
    overflow: hidden;
    border: 1px solid rgba(148, 163, 184, 0.22);
    border-radius: 1rem;
    background: #070707;
    box-shadow: 0 24px 62px rgba(0, 0, 0, 0.48);
    transform: rotate(-2deg);
  }

  .preview-bar {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    height: 2rem;
    padding: 0 0.65rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: #121212;
  }

  .preview-bar > span {
    width: 0.43rem;
    height: 0.43rem;
    border-radius: 50%;
    background: #ff675d;
  }

  .preview-bar > span:nth-child(2) {
    background: #ffbd44;
  }

  .preview-bar > span:nth-child(3) {
    background: #00ca4e;
  }

  .preview-bar small {
    margin-left: auto;
    color: rgba(255, 255, 255, 0.42);
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.08em;
  }

  .dicta-preview img {
    display: block;
    width: 100%;
    aspect-ratio: 1.5;
    object-fit: cover;
    object-position: center top;
  }

  .dentimed-preview {
    position: absolute;
    right: 1.1rem;
    bottom: -3.8rem;
    width: 31%;
    min-width: 150px;
    overflow: hidden;
    padding: 0.42rem 0.42rem 2.4rem;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 1.85rem;
    background: #0d1118;
    box-shadow: 0 28px 70px rgba(0, 0, 0, 0.58);
    transform: rotate(4deg);
  }

  .dentimed-preview img {
    display: block;
    width: 100%;
    border-radius: 1.45rem;
  }

  .dentimed-preview figcaption {
    position: absolute;
    left: 50%;
    bottom: 0.7rem;
    width: max-content;
    max-width: calc(100% - 1rem);
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.62);
    font-family: var(--font-mono);
    font-size: 0.51rem;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .phone-speaker {
    position: absolute;
    top: 0.78rem;
    left: 50%;
    z-index: 2;
    width: 2.8rem;
    height: 0.24rem;
    border-radius: 99px;
    background: rgba(0, 0, 0, 0.45);
    transform: translateX(-50%);
  }

  .stage-orbit {
    position: absolute;
    border: 1px solid rgba(34, 197, 94, 0.16);
    border-radius: 50%;
    pointer-events: none;
  }

  .stage-orbit-one {
    right: -4rem;
    top: -5rem;
    width: 16rem;
    height: 16rem;
  }

  .stage-orbit-two {
    left: -5rem;
    bottom: -7rem;
    width: 18rem;
    height: 18rem;
    border-color: rgba(59, 130, 246, 0.13);
  }

  @media (max-width: 1100px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }

    .hero-copy {
      max-width: 850px;
    }

    .hero-visual {
      max-width: 780px;
    }
  }

  @media (max-width: 640px) {
    .hero-section {
      padding-top: 7.5rem;
    }

    .hero-inner {
      width: min(100% - 1.25rem, 1380px);
      gap: 3rem;
    }

    h1 {
      font-size: clamp(3rem, 16vw, 4.8rem);
    }

    .hero-actions {
      display: grid;
    }

    .hero-actions :global(a) {
      width: 100%;
    }

    .hero-metrics {
      gap: 0.75rem;
    }

    .hero-metric span {
      font-size: 0.66rem;
    }

    .hero-visual {
      padding: 0.75rem;
      border-radius: 1.4rem;
    }

    .visual-heading {
      display: block;
    }

    .visual-status {
      margin-top: 1rem;
    }

    .product-stage {
      min-height: 340px;
    }

    .dicta-preview {
      top: 2rem;
      left: 0.8rem;
      width: 88%;
    }

    .dentimed-preview {
      right: 0.6rem;
      width: 34%;
      min-width: 120px;
    }
  }
</style>
