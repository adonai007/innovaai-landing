---
import Button from './Button.astro';

interface Props {
  hero: {
    headline: string;
    subheadline: string;
    ctaPrimary: string;
    ctaPrimaryHref: string;
    ctaSecondary: string;
    ctaSecondaryHref: string;
    badges: string[];
  };
}

const { hero } = Astro.props;
const words = hero.headline.split(' ');
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Aurora glow blobs (behind particles) -->
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="aurora-blob aurora-blob-1"></div>
    <div class="aurora-blob aurora-blob-2"></div>
    <div class="aurora-blob aurora-blob-3"></div>
  </div>

  <!-- Grid pattern (behind particles, in front of aurora) -->
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none hero-grid" aria-hidden="true"></div>

  <!-- Particle Background Slot -->
  <div id="particles-container" class="absolute inset-0 z-[1]"></div>

  <!-- Gradient Overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-bg-primary z-[2]"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 text-center pt-24">
    <!-- Headline -->
    <h1 class="text-[length:var(--text-hero)] font-bold leading-[1.1] mb-6" data-animate="hero-headline">
      {words.map((word, i) => (
        <span
          class={`inline-block opacity-0 translate-y-8 hero-word ${
            word === 'Inteligencia' || word === 'Artificial' || word === 'Intelligence'
              ? 'gradient-text'
              : ''
          }`}
          style={`animation-delay: ${i * 0.08}s`}
        >
          {word}&nbsp;
        </span>
      ))}
    </h1>

    <!-- Subheadline -->
    <p class="text-[length:var(--text-xl)] text-text-secondary max-w-2xl mx-auto mb-10 opacity-0" data-animate="hero-sub">
      {hero.subheadline}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12 opacity-0" data-animate="hero-ctas">
      <Button variant="primary" size="lg" href={hero.ctaPrimaryHref}>
        {hero.ctaPrimary}
      </Button>
      <Button variant="secondary" size="lg" href={hero.ctaSecondaryHref}>
        {hero.ctaSecondary}
      </Button>
    </div>

    <!-- Trust Badges -->
    <div class="flex flex-wrap justify-center gap-6 opacity-0" data-animate="hero-badges">
      {hero.badges.map(badge => (
        <div class="flex items-center gap-2 text-text-tertiary text-sm">
          <svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
          {badge}
        </div>
      ))}
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-0" data-animate="hero-scroll" style="animation: bounce-down 2s infinite">
      <svg class="w-6 h-6 text-text-tertiary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="m7 13 5 5 5-5M7 6l5 5 5-5"/>
      </svg>
    </div>
  </div>
</section>

<style>
  /* Grid pattern with radial mask — primary green at low alpha */
  .hero-grid {
    background-image:
      linear-gradient(rgba(22, 163, 74, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(22, 163, 74, 0.06) 1px, transparent 1px);
    background-size: 64px 64px;
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, black 40%, transparent 80%);
    mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, black 40%, transparent 80%);
  }

  /* Aurora blobs — leverage existing `float` keyframe in animations.css */
  .aurora-blob {
    position: absolute;
    border-radius: 50%;
    will-change: transform;
  }
  .aurora-blob-1 {
    top: -10%;
    left: 20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(22, 163, 74, 0.25), transparent 70%);
    filter: blur(80px);
    animation: float 12s ease-in-out infinite;
  }
  .aurora-blob-2 {
    top: 10%;
    right: 15%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(30, 64, 175, 0.2), transparent 70%);
    filter: blur(80px);
    animation: float 14s ease-in-out infinite reverse;
  }
  .aurora-blob-3 {
    bottom: -10%;
    left: 40%;
    width: 700px;
    height: 400px;
    background: radial-gradient(circle, rgba(6, 182, 212, 0.15), transparent 70%);
    filter: blur(100px);
    animation: float 18s ease-in-out infinite;
  }
</style>
