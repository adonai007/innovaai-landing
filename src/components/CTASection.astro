---
import Button from './Button.astro';

interface Props {
  cta: {
    eyebrow: string;
    titleBefore: string;
    titleAccent: string;
    subtitle: string;
    ctaPrimary: string;
    ctaPrimaryHref: string;
    ctaSecondary: string;
    ctaSecondaryHref: string;
    note: string;
    whatsappNumber: string;
    whatsappMessage: string;
  };
}

const { cta } = Astro.props;
---

<section id="contacto" class="cta-section section-padding">
  <div class="cta-shell" data-animate="fade-up">
    <div class="cta-grid" aria-hidden="true"></div>
    <div class="cta-glow" aria-hidden="true"></div>

    <div class="cta-content">
      <span class="cta-eyebrow">
        <span></span>
        {cta.eyebrow}
      </span>
      <h2>
        {cta.titleBefore}
        <span class="gradient-text">{cta.titleAccent}</span>
      </h2>
      <p>{cta.subtitle}</p>

      <div class="cta-actions">
        <Button variant="primary" size="lg" href={cta.ctaPrimaryHref}>
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
          </svg>
          {cta.ctaPrimary}
        </Button>
        <Button variant="secondary" size="lg" href={cta.ctaSecondaryHref}>
          {cta.ctaSecondary}
        </Button>
      </div>

      <span class="cta-note">{cta.note}</span>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding-top: clamp(3rem, 6vw, 6rem);
  }

  .cta-shell {
    position: relative;
    width: min(100% - 2rem, 1380px);
    overflow: hidden;
    margin: 0 auto;
    padding: clamp(3.2rem, 8vw, 7.5rem) clamp(1.25rem, 7vw, 7rem);
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 2rem;
    background:
      linear-gradient(135deg, rgba(34, 197, 94, 0.1), rgba(7, 15, 27, 0.82) 42%, rgba(59, 130, 246, 0.09)),
      #08111f;
    box-shadow:
      0 35px 110px rgba(0, 0, 0, 0.36),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .cta-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(148, 163, 184, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.04) 1px, transparent 1px);
    background-size: 54px 54px;
    mask-image: radial-gradient(circle at center, black, transparent 82%);
  }

  .cta-glow {
    position: absolute;
    top: 50%;
    right: -10%;
    width: 34rem;
    height: 34rem;
    border: 1px solid rgba(34, 197, 94, 0.14);
    border-radius: 50%;
    transform: translateY(-50%);
    box-shadow:
      0 0 0 3rem rgba(34, 197, 94, 0.025),
      0 0 0 6rem rgba(59, 130, 246, 0.018);
  }

  .cta-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
  }

  .cta-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--color-primary-light);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
  }

  .cta-eyebrow span {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--color-primary-light);
    box-shadow: 0 0 12px var(--color-primary);
  }

  h2 {
    margin: 1.3rem 0 0;
    font-size: clamp(2.8rem, 6vw, 6.5rem);
    line-height: 0.95;
    letter-spacing: -0.065em;
    text-wrap: balance;
  }

  h2 span {
    display: block;
  }

  .cta-content > p {
    max-width: 680px;
    margin: 1.6rem 0 0;
    color: var(--color-text-secondary);
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.7;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 2rem;
  }

  .cta-actions svg {
    width: 1.2rem;
    height: 1.2rem;
    margin-right: 0.6rem;
  }

  .cta-note {
    display: block;
    margin-top: 1rem;
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.04em;
  }

  @media (max-width: 640px) {
    .cta-shell {
      width: min(100% - 1.25rem, 1380px);
      border-radius: 1.4rem;
    }

    .cta-actions {
      display: grid;
    }

    .cta-actions :global(a) {
      width: 100%;
    }
  }
</style>
