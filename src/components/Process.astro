---
interface Props {
  section: {
    badge: string;
    titleBefore: string;
    titleAccent: string;
    subtitle: string;
  };
  steps: {
    number: string;
    timing: string;
    title: string;
    description: string;
    output: string;
  }[];
}

const { section, steps } = Astro.props;
---

<section id="proceso" class="process-section section-padding">
  <div class="section-shell">
    <header class="process-intro" data-animate="fade-up">
      <div>
        <span class="section-kicker">{section.badge}</span>
        <h2>
          {section.titleBefore}
          <span class="gradient-text">{section.titleAccent}</span>
        </h2>
      </div>
      <p>{section.subtitle}</p>
    </header>

    <div class="process-grid">
      <div class="process-line" aria-hidden="true"></div>
      {steps.map((step, index) => (
        <article
          class="process-step"
          data-animate="fade-up"
          data-delay={index * 0.12}
        >
          <div class="process-marker">
            <span>{step.number}</span>
          </div>
          <span class="process-timing">{step.timing}</span>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
          <div class="process-output">
            <span aria-hidden="true"></span>
            {step.output}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .process-section {
    position: relative;
  }

  .section-shell {
    width: min(100% - 2rem, 1380px);
    margin: 0 auto;
  }

  .process-intro {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.65fr);
    gap: clamp(2rem, 6vw, 7rem);
    align-items: end;
    margin-bottom: clamp(3.5rem, 7vw, 6rem);
  }

  .section-kicker {
    display: block;
    margin-bottom: 1rem;
    color: var(--color-primary-light);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.16em;
  }

  h2 {
    margin: 0;
    font-size: clamp(2.65rem, 5.4vw, 5.6rem);
    line-height: 0.98;
    letter-spacing: -0.06em;
    text-wrap: balance;
  }

  h2 span {
    display: inline-block;
    margin-left: 0.12em;
  }

  .process-intro > p {
    margin: 0 0 0.35rem;
    color: var(--color-text-secondary);
    font-size: clamp(1rem, 1.35vw, 1.15rem);
    line-height: 1.7;
  }

  .process-grid {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .process-line {
    position: absolute;
    top: 1.55rem;
    left: 3rem;
    width: 0;
    max-width: calc(100% - 6rem);
    height: 1px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-secondary-light));
    box-shadow: 0 0 16px rgba(34, 197, 94, 0.38);
  }

  .process-step {
    position: relative;
    min-height: 360px;
    padding: 0 1.35rem 1.6rem;
    border-left: 1px solid rgba(148, 163, 184, 0.14);
  }

  .process-marker {
    position: relative;
    z-index: 2;
    display: grid;
    width: 3.1rem;
    height: 3.1rem;
    margin-left: -1.35rem;
    place-items: center;
    border: 1px solid rgba(34, 197, 94, 0.28);
    border-radius: 50%;
    color: var(--color-primary-light);
    background: var(--color-bg-primary);
    box-shadow:
      0 0 0 7px var(--color-bg-primary),
      0 0 25px rgba(34, 197, 94, 0.12);
  }

  .process-marker span {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
  }

  .process-timing {
    display: block;
    margin-top: 2.25rem;
    color: var(--color-primary-light);
    font-family: var(--font-mono);
    font-size: 0.63rem;
    letter-spacing: 0.14em;
  }

  h3 {
    margin: 0.8rem 0 0;
    font-size: clamp(1.3rem, 1.9vw, 1.75rem);
    line-height: 1.1;
    letter-spacing: -0.04em;
  }

  .process-step > p {
    margin: 0.9rem 0 0;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .process-output {
    position: absolute;
    right: 1.35rem;
    bottom: 1.6rem;
    left: 1.35rem;
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(148, 163, 184, 0.12);
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    line-height: 1.4;
  }

  .process-output span {
    flex: none;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--color-primary-light);
    box-shadow: 0 0 10px var(--color-primary);
  }

  @media (max-width: 980px) {
    .process-intro {
      grid-template-columns: 1fr;
      gap: 1.6rem;
    }

    .process-intro > p {
      max-width: 44rem;
    }

    .process-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2.5rem 1rem;
    }

    .process-line {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .section-shell {
      width: min(100% - 1.25rem, 1380px);
    }

    h2 span {
      display: block;
      margin-left: 0;
    }

    .process-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .process-step {
      min-height: 330px;
    }
  }
</style>
