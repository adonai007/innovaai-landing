---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  href?: string;
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const {
  variant = 'primary',
  href,
  size = 'md',
  class: className = '',
} = Astro.props;

const baseClasses =
  'button-base inline-flex items-center justify-center font-semibold transition-all duration-300 cursor-pointer';

const sizeClasses = {
  sm: 'px-4 py-2.5 text-sm',
  md: 'px-5 py-3.5 text-sm sm:text-base',
  lg: 'px-6 sm:px-7 py-4 text-base sm:text-lg',
};

const variantClasses = {
  primary: 'button-primary',
  secondary: 'button-secondary',
  ghost: 'button-ghost',
};

const classes = `${baseClasses} ${sizeClasses[size]} ${variantClasses[variant]} ${className}`;
const Tag = href ? 'a' : 'button';
const isExternal = typeof href === 'string' && /^https?:\/\//.test(href);
---

<Tag
  href={href}
  class={classes}
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noopener noreferrer' : undefined}
>
  <slot />
</Tag>

<style>
  .button-base {
    min-height: 44px;
    border-radius: 0.8rem;
    letter-spacing: -0.01em;
  }

  .button-primary {
    color: #03120a;
    background: linear-gradient(135deg, var(--color-primary-light), var(--color-primary));
    border: 1px solid rgba(113, 255, 168, 0.5);
    box-shadow:
      0 12px 34px rgba(34, 197, 94, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.35);
  }

  .button-primary:hover {
    transform: translateY(-2px);
    filter: brightness(1.06);
    box-shadow:
      0 18px 46px rgba(34, 197, 94, 0.26),
      inset 0 1px 0 rgba(255, 255, 255, 0.4);
  }

  .button-secondary {
    color: var(--color-text-primary);
    background: rgba(9, 17, 30, 0.72);
    border: 1px solid rgba(148, 163, 184, 0.26);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .button-secondary:hover {
    transform: translateY(-2px);
    border-color: rgba(34, 197, 94, 0.55);
    background: rgba(34, 197, 94, 0.08);
  }

  .button-ghost {
    color: var(--color-text-secondary);
    background: transparent;
  }

  .button-ghost:hover {
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.05);
  }
</style>
