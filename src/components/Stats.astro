---
interface Props {
  section: { badge: string; title: string; subtitle: string };
  differentiators: { icon: string; title: string; description: string; accent: 'primary' | 'secondary' }[];
}

const { section, differentiators } = Astro.props;
---

<section class="section-padding relative overflow-hidden">
  <!-- Background Decoration -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-primary/[0.03] blur-[100px]"></div>
    <div class="absolute top-1/4 right-0 w-[300px] h-[300px] rounded-full bg-secondary/[0.04] blur-[80px]"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16" data-animate="fade-up">
      <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold tracking-wider uppercase bg-primary/10 text-primary border border-primary/20 mb-4">
        {section.badge}
      </span>
      <h2 class="text-[length:var(--text-4xl)] font-bold mb-4">
        <span class="gradient-text">{section.title}</span>
      </h2>
      <p class="text-text-secondary text-[length:var(--text-xl)] max-w-2xl mx-auto">{section.subtitle}</p>
    </div>

    <!-- Differentiators Grid -->
    <div class="grid md:grid-cols-2 gap-5 lg:gap-6">
      {differentiators.map((item, i) => (
        <div
          class="group relative rounded-2xl p-[1px] transition-all duration-500 hover:scale-[1.02]"
          data-animate="fade-up"
          data-delay={i * 0.12}
        >
          <!-- Gradient border -->
          <div class={`absolute inset-0 rounded-2xl opacity-30 group-hover:opacity-100 transition-opacity duration-500 ${
            item.accent === 'primary'
              ? 'bg-gradient-to-br from-primary/50 via-transparent to-primary/15'
              : 'bg-gradient-to-br from-secondary/50 via-transparent to-secondary/15'
          }`}></div>

          <!-- Card content -->
          <div class="relative rounded-2xl bg-bg-secondary/80 backdrop-blur-sm p-8 h-full flex gap-5">
            <!-- Icon -->
            <div class={`w-14 h-14 rounded-xl flex items-center justify-center shrink-0 ${
              item.accent === 'primary'
                ? 'bg-primary/10 text-primary shadow-[0_0_25px_rgba(34,197,94,0.15)]'
                : 'bg-secondary/10 text-secondary shadow-[0_0_25px_rgba(59,130,246,0.15)]'
            }`}>
              {item.icon === 'globe' && (
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
              )}
              {item.icon === 'target' && (
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
              )}
              {item.icon === 'shield' && (
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              )}
              {item.icon === 'handshake' && (
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m11 17 2 2a1 1 0 1 0 3-3"/><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"/><path d="m21 3 1 11h-2"/><path d="M3 3 2 14h2"/><path d="m3 3 7.07 7.07"/><path d="m7.18 11.82-4.12 4.12a1 1 0 1 0 3 3l4.12-4.12"/></svg>
              )}
            </div>

            <!-- Text -->
            <div>
              <h3 class="text-lg font-bold mb-2 group-hover:text-text-primary transition-colors">{item.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{item.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
