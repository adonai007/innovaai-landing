---
interface Props {
  section: {
    badge: string;
    titleBefore: string;
    titleAccent: string;
    subtitle: string;
  };
  differentiators: {
    icon: string;
    title: string;
    description: string;
    accent: 'primary' | 'secondary';
    featured?: boolean;
  }[];
}

const { section, differentiators } = Astro.props;
---

<section class="why-section section-padding">
  <div class="section-shell">
    <header class="why-intro" data-animate="fade-up">
      <span class="section-kicker">{section.badge}</span>
      <h2>
        <span>{section.titleBefore}</span>
        <span class="gradient-text">{section.titleAccent}</span>
      </h2>
      <p>{section.subtitle}</p>
    </header>

    <div class="why-grid">
      {differentiators.map((item, index) => (
        <article
          class:list={[
            'why-card',
            `accent-${item.accent}`,
            { featured: item.featured },
          ]}
          data-animate="fade-up"
          data-delay={index * 0.1}
        >
          <div class="why-card-top">
            <div class="why-icon" aria-hidden="true">
              {item.icon === 'experience' && (
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M4 19V9M10 19V5M16 19v-7M22 19V3" />
                  <path d="M2 19h22" />
                </svg>
              )}
              {item.icon === 'product' && (
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="m12 2 8 4.5v10L12 21l-8-4.5v-10Z" />
                  <path d="m4 6.5 8 4.5 8-4.5M12 11v10" />
                </svg>
              )}
              {item.icon === 'human' && (
                <svg viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="8" r="3.5" />
                  <path d="M5 21c.8-4 3.1-6 7-6s6.2 2 7 6" />
                  <path d="m17.5 4.5 1.3 1.3 2.7-2.7" />
                </svg>
              )}
              {item.icon === 'latam' && (
                <svg viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="9" />
                  <path d="M3 12h18M12 3c2.7 2.6 4 5.6 4 9s-1.3 6.4-4 9c-2.7-2.6-4-5.6-4-9s1.3-6.4 4-9Z" />
                </svg>
              )}
            </div>
            <span class="why-index">0{index + 1}</span>
          </div>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .why-section {
    position: relative;
    overflow: hidden;
    border-top: 1px solid rgba(148, 163, 184, 0.09);
    background:
      radial-gradient(circle at 72% 34%, rgba(59, 130, 246, 0.06), transparent 28%),
      rgba(8, 15, 27, 0.64);
  }

  .section-shell {
    width: min(100% - 2rem, 1380px);
    margin: 0 auto;
  }

  .why-intro {
    max-width: 990px;
    margin-bottom: clamp(3.5rem, 7vw, 6rem);
  }

  .section-kicker {
    display: block;
    margin-bottom: 1rem;
    color: var(--color-primary-light);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.16em;
  }

  h2 {
    margin: 0;
    font-size: clamp(2.65rem, 5.4vw, 5.6rem);
    line-height: 0.98;
    letter-spacing: -0.06em;
    text-wrap: balance;
  }

  h2 > span {
    display: block;
  }

  .why-intro > p {
    max-width: 720px;
    margin: 1.5rem 0 0;
    color: var(--color-text-secondary);
    font-size: clamp(1rem, 1.35vw, 1.17rem);
    line-height: 1.7;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .why-card {
    --card-accent: var(--color-primary-light);
    position: relative;
    min-height: 310px;
    overflow: hidden;
    padding: clamp(1.5rem, 3vw, 2.4rem);
    border: 1px solid rgba(148, 163, 184, 0.14);
    border-radius: 1.35rem;
    background:
      linear-gradient(145deg, rgba(20, 33, 52, 0.78), rgba(9, 17, 29, 0.72));
    transition: transform 260ms ease, border-color 260ms ease;
  }

  .why-card::after {
    content: '';
    position: absolute;
    right: -4rem;
    bottom: -5rem;
    width: 12rem;
    height: 12rem;
    border-radius: 50%;
    background: var(--card-accent);
    filter: blur(80px);
    opacity: 0.08;
  }

  .why-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--card-accent) 36%, transparent);
  }

  .why-card.accent-secondary {
    --card-accent: var(--color-secondary-light);
  }

  .why-card.featured {
    grid-column: span 2;
    min-height: 370px;
    background:
      linear-gradient(115deg, rgba(34, 197, 94, 0.11), transparent 42%),
      linear-gradient(145deg, rgba(20, 33, 52, 0.88), rgba(9, 17, 29, 0.8));
  }

  .why-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .why-icon {
    display: grid;
    width: 3.3rem;
    height: 3.3rem;
    place-items: center;
    border: 1px solid color-mix(in srgb, var(--card-accent) 25%, transparent);
    border-radius: 1rem;
    color: var(--card-accent);
    background: color-mix(in srgb, var(--card-accent) 10%, transparent);
  }

  .why-icon svg {
    width: 1.5rem;
    height: 1.5rem;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .why-index {
    color: rgba(148, 163, 184, 0.36);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
  }

  h3 {
    max-width: 650px;
    margin: clamp(2rem, 5vw, 4.5rem) 0 0;
    font-size: clamp(1.65rem, 2.8vw, 3rem);
    line-height: 1.04;
    letter-spacing: -0.05em;
  }

  .why-card:not(.featured) h3 {
    font-size: clamp(1.45rem, 2.1vw, 2rem);
  }

  .why-card > p {
    position: relative;
    z-index: 1;
    max-width: 680px;
    margin: 1rem 0 0;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  @media (min-width: 981px) {
    .why-card:nth-child(2),
    .why-card:nth-child(3),
    .why-card:nth-child(4) {
      grid-column: span 1;
    }

    .why-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .why-card.featured {
      grid-column: span 3;
    }
  }

  @media (max-width: 640px) {
    .section-shell {
      width: min(100% - 1.25rem, 1380px);
    }

    .why-grid {
      grid-template-columns: 1fr;
    }

    .why-card,
    .why-card.featured {
      grid-column: auto;
      min-height: 300px;
    }
  }
</style>
