---
import Button from '../Button.astro';

interface Props {
  cta: {
    title: string;
    subtitle: string;
    ctaPrimary: string;
    ctaPrimaryHref: string;
    ctaSecondary: string;
    ctaSecondaryHref: string;
  };
}

const { cta } = Astro.props;
---

<section id="cta-final" class="section-padding relative overflow-hidden">
  <!-- Green gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary/15 via-bg-primary to-secondary/10 pointer-events-none"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(22,163,74,0.1),transparent_60%)] pointer-events-none"></div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center" data-animate="fade-up">
    <h2 class="text-[length:var(--text-4xl)] font-bold mb-6">{cta.title}</h2>
    <p class="text-text-secondary text-[length:var(--text-xl)] mb-10">{cta.subtitle}</p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button variant="primary" size="lg" href={cta.ctaPrimaryHref} class="animate-[glow-pulse_3s_infinite]">
        {cta.ctaPrimary}
      </Button>
      <Button variant="secondary" size="lg" href={cta.ctaSecondaryHref}>
        {cta.ctaSecondary}
      </Button>
    </div>
  </div>
</section>
