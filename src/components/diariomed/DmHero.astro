---
import Button from '../Button.astro';

interface Props {
  hero: {
    badge: string;
    headline: string;
    subheadline: string;
    ctaPrimary: string;
    ctaPrimaryHref: string;
    ctaSecondary: string;
    ctaSecondaryHref: string;
    trustItems: string[];
  };
}

const { hero } = Astro.props;
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Particle Background Slot -->
  <div id="particles-container" class="absolute inset-0 z-0"></div>

  <!-- Radial green gradient -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(22,163,74,0.12),transparent_60%)] z-[1]"></div>

  <!-- Fade to bg at bottom -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-bg-primary z-[1]"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 text-center pt-28 pb-16">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass text-sm text-primary font-medium mb-8 opacity-0" data-animate="hero-sub">
      <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
      {hero.badge}
    </div>

    <!-- Headline -->
    <h1 class="text-[length:var(--text-hero)] font-bold leading-[1.1] mb-6" data-animate="hero-headline">
      {hero.headline.split(' ').map((word, i) => (
        <span
          class={`inline-block opacity-0 translate-y-8 hero-word ${
            word === 'DentiMed' ? 'gradient-text' : ''
          }`}
          style={`animation-delay: ${i * 0.08}s`}
        >
          {word}&nbsp;
        </span>
      ))}
    </h1>

    <!-- Subheadline -->
    <p class="text-[length:var(--text-xl)] text-text-secondary max-w-2xl mx-auto mb-10 opacity-0" data-animate="hero-sub">
      {hero.subheadline}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12 opacity-0" data-animate="hero-ctas">
      <Button variant="primary" size="lg" href={hero.ctaPrimaryHref}>
        {hero.ctaPrimary}
      </Button>
      <Button variant="secondary" size="lg" href={hero.ctaSecondaryHref}>
        {hero.ctaSecondary}
      </Button>
    </div>

    <!-- Trust bar -->
    <div class="flex flex-wrap justify-center gap-6 opacity-0" data-animate="hero-badges">
      {hero.trustItems.map(item => (
        <div class="flex items-center gap-2 text-text-tertiary text-sm">
          <svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          {item}
        </div>
      ))}
    </div>
  </div>
</section>
