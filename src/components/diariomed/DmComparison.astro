---
interface Row {
  feature: string;
  diariomed: string;
  wispr: string;
  cloudEmr: string;
}

interface Props {
  section: {
    sectionTitle: string;
    sectionSubtitle: string;
    columns: { diariomed: string; wispr: string; cloudEmr: string };
    rows: Row[];
    note: string;
    recommendedLabel?: string;
  };
}

const { section } = Astro.props;
const recommendedLabel = section.recommendedLabel ?? 'Recomendado';

// Render a cell: "Si" -> green check, "No" -> red x, else plain text
const renderCell = (value: string) => {
  const v = value.trim().toLowerCase();
  if (v === 'si' || v === 'sí' || v === 'yes') return { type: 'yes', text: '' };
  if (v === 'no') return { type: 'no', text: '' };
  return { type: 'text', text: value };
};
---

<section id="comparativa" class="section-padding relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(22,163,74,0.04),transparent_60%)] pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <h2 class="text-[length:var(--text-4xl)] font-bold mb-4" data-animate="fade-up">
        {section.sectionTitle}
      </h2>
      <p class="text-text-secondary text-[length:var(--text-xl)]" data-animate="fade-up">
        {section.sectionSubtitle}
      </p>
    </div>

    <div class="glass rounded-2xl overflow-hidden" data-animate="fade-up">
      <div class="overflow-x-auto">
        <table class="w-full min-w-[640px] text-sm">
          <thead>
            <tr class="border-b border-bg-glass-border">
              <th class="text-left p-4 md:p-5 font-semibold text-text-secondary uppercase text-xs tracking-wider">
                Feature
              </th>
              <th class="p-4 md:p-5 font-bold bg-primary/10 border-x border-primary/20">
                <div class="gradient-text text-base md:text-lg">{section.columns.diariomed}</div>
                <div class="text-xs text-primary/80 font-medium mt-0.5">{recommendedLabel}</div>
              </th>
              <th class="p-4 md:p-5 font-semibold text-text-secondary">
                {section.columns.wispr}
              </th>
              <th class="p-4 md:p-5 font-semibold text-text-secondary">
                {section.columns.cloudEmr}
              </th>
            </tr>
          </thead>
          <tbody>
            {section.rows.map((row, i) => {
              const d = renderCell(row.diariomed);
              const w = renderCell(row.wispr);
              const c = renderCell(row.cloudEmr);
              return (
                <tr class={`${i % 2 === 0 ? 'bg-white/[0.015]' : ''} border-b border-bg-glass-border/50 last:border-b-0`}>
                  <td class="p-4 md:p-5 text-text-primary font-medium">
                    {row.feature}
                  </td>
                  <td class="p-4 md:p-5 text-center bg-primary/5 border-x border-primary/20">
                    {d.type === 'yes' && (
                      <svg class="w-5 h-5 mx-auto text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    )}
                    {d.type === 'no' && (
                      <svg class="w-5 h-5 mx-auto text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>
                    )}
                    {d.type === 'text' && <span class="text-primary font-semibold">{d.text}</span>}
                  </td>
                  <td class="p-4 md:p-5 text-center">
                    {w.type === 'yes' && (
                      <svg class="w-5 h-5 mx-auto text-text-secondary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    )}
                    {w.type === 'no' && (
                      <svg class="w-5 h-5 mx-auto text-text-tertiary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>
                    )}
                    {w.type === 'text' && <span class="text-text-secondary">{w.text}</span>}
                  </td>
                  <td class="p-4 md:p-5 text-center">
                    {c.type === 'yes' && (
                      <svg class="w-5 h-5 mx-auto text-text-secondary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    )}
                    {c.type === 'no' && (
                      <svg class="w-5 h-5 mx-auto text-text-tertiary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>
                    )}
                    {c.type === 'text' && <span class="text-text-secondary">{c.text}</span>}
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>

    <p class="text-center text-text-tertiary text-sm mt-6 max-w-2xl mx-auto" data-animate="fade-up">
      {section.note}
    </p>
  </div>
</section>
