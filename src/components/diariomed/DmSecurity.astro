---
interface Card {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  section: {
    sectionTitle: string;
    sectionSubtitle: string;
    cards: Card[];
    badges: string[];
  };
}

const { section } = Astro.props;

const iconMap: Record<string, string> = {
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>',
  lock: '<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  server: '<rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/>',
  'eye-off': '<path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" x2="22" y1="2" y2="22"/>',
};
---

<section id="seguridad" class="section-padding relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,rgba(30,64,175,0.06),transparent_60%)] pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <h2 class="text-[length:var(--text-4xl)] font-bold mb-4" data-animate="fade-up">
        {section.sectionTitle}
      </h2>
      <p class="text-text-secondary text-[length:var(--text-xl)]" data-animate="fade-up">
        {section.sectionSubtitle}
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6 max-w-4xl mx-auto mb-16">
      {section.cards.map((card, i) => (
        <div
          class="glass rounded-2xl p-8 transition-all duration-300 hover:-translate-y-1 hover:border-primary/30 hover:shadow-[0_0_30px_rgba(22,163,74,0.1)]"
          data-animate="fade-up"
          data-delay={String(i * 0.08)}
        >
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary/20 to-secondary/10 border border-primary/20 flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={iconMap[card.icon] || ''} />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">{card.title}</h3>
          <p class="text-text-secondary text-sm leading-relaxed">{card.description}</p>
        </div>
      ))}
    </div>

    <!-- Badge row -->
    <div class="flex flex-wrap items-center justify-center gap-3 sm:gap-4" data-animate="fade-up">
      {section.badges.map((b) => (
        <div class="glass rounded-full px-5 py-2 text-sm font-semibold text-text-secondary border border-bg-glass-border hover:border-primary/40 hover:text-primary transition-colors duration-300">
          {b}
        </div>
      ))}
    </div>
  </div>
</section>
