---
interface Problem {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  section: {
    sectionTitle: string;
    sectionSubtitle: string;
    problems: Problem[];
  };
}

const { section } = Astro.props;

const iconMap: Record<string, string> = {
  clock: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  money: '<line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>',
  warning: '<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/>',
  lock: '<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
};
---

<section id="problema" class="section-padding relative overflow-hidden">
  <!-- Subtle bg gradient -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(245,158,11,0.04),transparent_60%)] pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <h2 class="text-[length:var(--text-4xl)] font-bold mb-4" data-animate="fade-up">
        {section.sectionTitle}
      </h2>
      <p class="text-text-secondary text-[length:var(--text-xl)]" data-animate="fade-up">
        {section.sectionSubtitle}
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {section.problems.map((p, i) => (
        <div
          class="glass rounded-2xl p-6 flex items-start gap-4 transition-all duration-300 hover:-translate-y-1 hover:border-amber-500/30"
          data-animate="fade-up"
          data-delay={String(i * 0.08)}
        >
          <div class="w-12 h-12 shrink-0 rounded-xl bg-gradient-to-br from-amber-500/20 to-amber-500/5 border border-amber-500/20 flex items-center justify-center">
            <svg class="w-6 h-6 text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={iconMap[p.icon] || ''} />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold mb-1">{p.title}</h3>
            <p class="text-text-secondary text-sm leading-relaxed">{p.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
