---
interface Counter {
  value: string;
  label: string;
  sublabel?: string;
}

interface Testimonial {
  quote: string;
  author: string;
  role: string;
  location: string;
}

interface Props {
  section: {
    sectionTitle: string;
    sectionSubtitle: string;
    counters: Counter[];
    testimonials: Testimonial[];
  };
}

const { section } = Astro.props;
---

<section id="resultados" class="section-padding relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(34,197,94,0.06),transparent_60%)] pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-[length:var(--text-4xl)] font-bold mb-4" data-animate="fade-up">
        {section.sectionTitle}
      </h2>
      <p class="text-text-secondary text-[length:var(--text-xl)]" data-animate="fade-up">
        {section.sectionSubtitle}
      </p>
    </div>

    <!-- Counter cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 mb-20">
      {section.counters.map((c, i) => (
        <div
          class="glass rounded-2xl p-6 text-center transition-all duration-300 hover:-translate-y-1 hover:border-primary/30 hover:shadow-[0_0_30px_rgba(34,197,94,0.1)]"
          data-animate="fade-up"
          data-delay={String(i * 0.08)}
        >
          <div
            class="dm-counter text-3xl md:text-4xl lg:text-5xl font-bold gradient-text mb-2"
            data-value={c.value}
          >
            {c.value}
          </div>
          <div class="text-sm font-semibold text-text-primary">{c.label}</div>
          {c.sublabel && (
            <div class="text-xs text-text-tertiary mt-1">{c.sublabel}</div>
          )}
        </div>
      ))}
    </div>

    <!-- Testimonials -->
    <div class="flex flex-wrap justify-center gap-6">
      {section.testimonials.map((t, i) => (
        <div
          class="glass rounded-2xl p-6 flex flex-col w-full md:w-[340px] max-w-2xl transition-all duration-300 hover:-translate-y-1 hover:border-primary/30"
          data-animate="fade-up"
          data-delay={String(i * 0.1)}
        >
          <svg class="w-8 h-8 text-primary/60 mb-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M9.352 4C4.456 7.456 1 13.12 1 19.36c0 5.088 3.072 8.064 6.624 8.064 3.36 0 5.856-2.688 5.856-5.856 0-3.168-2.208-5.472-5.088-5.472-.576 0-1.344.096-1.536.192.48-3.264 3.552-7.104 6.624-9.024L9.352 4zm11.04 0c-4.8 3.456-8.256 9.12-8.256 15.36 0 5.088 3.072 8.064 6.624 8.064 3.264 0 5.856-2.688 5.856-5.856 0-3.168-2.304-5.472-5.184-5.472-.576 0-1.248.096-1.44.192.48-3.264 3.456-7.104 6.528-9.024L20.392 4z"/>
          </svg>
          <p class="text-text-primary text-sm leading-relaxed mb-6 flex-1">"{t.quote}"</p>
          <div class="pt-4 border-t border-bg-glass-border">
            <div class="text-sm font-bold text-text-primary">{t.author}</div>
            <div class="text-xs text-text-secondary">{t.role}</div>
            <div class="text-xs text-text-tertiary">{t.location}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Animate counters on scroll into view
  const counters = document.querySelectorAll<HTMLElement>('.dm-counter');

  const animateCounter = (el: HTMLElement) => {
    const raw = el.dataset.value || el.textContent || '';
    // Extract numeric portion (supports: "15", "40%", "<1s", "85%")
    const match = raw.match(/([<>]?)(\d+(?:\.\d+)?)(.*)/);
    if (!match) return;
    const prefix = match[1] || '';
    const target = parseFloat(match[2]);
    const suffix = match[3] || '';

    // If value starts with "<" don't really animate, keep as is
    if (prefix === '<') {
      el.textContent = raw;
      return;
    }

    const duration = 1400;
    const start = performance.now();
    const step = (now: number) => {
      const p = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      const current = Math.floor(eased * target);
      el.textContent = `${prefix}${current}${suffix}`;
      if (p < 1) requestAnimationFrame(step);
      else el.textContent = raw;
    };
    requestAnimationFrame(step);
  };

  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          animateCounter(entry.target as HTMLElement);
          io.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.4 }
  );

  counters.forEach((c) => {
    // Start empty so animation is visible
    c.textContent = '0';
    io.observe(c);
  });
</script>
