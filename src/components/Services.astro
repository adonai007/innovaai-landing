---
interface Props {
  section: {
    badge: string;
    titleBefore: string;
    titleAccent: string;
    subtitle: string;
    image: string;
    imageAlt: string;
    imageEyebrow: string;
    imageTitle: string;
  };
  services: {
    number: string;
    icon: string;
    title: string;
    description: string;
    deliverable: string;
  }[];
}

const { section, services } = Astro.props;
---

<section id="servicios" class="services-section section-padding">
  <div class="section-shell">
    <header class="section-intro" data-animate="fade-up">
      <div>
        <span class="section-kicker">{section.badge}</span>
        <h2>
          {section.titleBefore}
          <span class="gradient-text">{section.titleAccent}</span>
        </h2>
      </div>
      <p>{section.subtitle}</p>
    </header>

    <div class="services-layout">
      <figure class="services-photo" data-animate="fade-up">
        <img
          src={section.image}
          alt={section.imageAlt}
          width="1536"
          height="1024"
          loading="lazy"
        />
        <div class="photo-overlay">
          <span>{section.imageEyebrow}</span>
          <figcaption>{section.imageTitle}</figcaption>
        </div>
      </figure>

      <div class="service-list">
        {services.map((service, index) => (
          <article
            class="service-row"
            data-animate="fade-up"
            data-delay={index * 0.12}
          >
            <div class="service-index">{service.number}</div>
            <div class="service-icon" aria-hidden="true">
              {service.icon === 'search' && (
                <svg viewBox="0 0 24 24" fill="none">
                  <circle cx="11" cy="11" r="6.5" />
                  <path d="m16 16 4.5 4.5M8 11h6M11 8v6" />
                </svg>
              )}
              {service.icon === 'build' && (
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M4 18.5 9.5 13l3 3L20 8.5" />
                  <path d="M15 8.5h5v5M4 5h8M4 9h5" />
                </svg>
              )}
              {service.icon === 'adopt' && (
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M8.5 12.5 11 15l5-6" />
                  <circle cx="12" cy="12" r="8.5" />
                  <path d="M12 3.5V1M12 23v-2.5M20.5 12H23M1 12h2.5" />
                </svg>
              )}
            </div>
            <div class="service-content">
              <h3>{service.title}</h3>
              <p>{service.description}</p>
              <span class="service-output">
                <svg aria-hidden="true" viewBox="0 0 20 20" fill="none">
                  <path d="m5 10 3 3 7-7" />
                </svg>
                {service.deliverable}
              </span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .services-section {
    position: relative;
  }

  .section-shell {
    width: min(100% - 2rem, 1380px);
    margin: 0 auto;
  }

  .section-intro {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.62fr);
    gap: clamp(2rem, 6vw, 7rem);
    align-items: end;
    margin-bottom: clamp(3rem, 6vw, 5.5rem);
  }

  .section-kicker {
    display: block;
    margin-bottom: 1rem;
    color: var(--color-primary-light);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.16em;
  }

  h2 {
    max-width: 860px;
    margin: 0;
    font-size: clamp(2.65rem, 5.4vw, 5.6rem);
    line-height: 0.98;
    letter-spacing: -0.06em;
    text-wrap: balance;
  }

  h2 span {
    display: inline-block;
    margin-left: 0.14em;
  }

  .section-intro > p {
    margin: 0 0 0.35rem;
    color: var(--color-text-secondary);
    font-size: clamp(1rem, 1.35vw, 1.15rem);
    line-height: 1.7;
  }

  .services-layout {
    display: grid;
    grid-template-columns: minmax(380px, 0.85fr) minmax(0, 1.15fr);
    gap: clamp(2rem, 5vw, 5.4rem);
    align-items: stretch;
  }

  .services-photo {
    position: relative;
    min-height: 620px;
    overflow: hidden;
    margin: 0;
    border: 1px solid rgba(148, 163, 184, 0.14);
    border-radius: 1.8rem;
    background: var(--color-bg-secondary);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.3);
  }

  .services-photo::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, rgba(4, 10, 18, 0.96), transparent 55%),
      linear-gradient(135deg, rgba(34, 197, 94, 0.08), transparent 45%);
  }

  .services-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .photo-overlay {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 1;
    padding: clamp(1.5rem, 4vw, 2.5rem);
  }

  .photo-overlay span {
    color: var(--color-primary-light);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
  }

  .photo-overlay figcaption {
    max-width: 30rem;
    margin-top: 0.7rem;
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 2.4vw, 2.4rem);
    font-weight: 650;
    line-height: 1.08;
    letter-spacing: -0.035em;
  }

  .service-list {
    border-top: 1px solid rgba(148, 163, 184, 0.16);
  }

  .service-row {
    display: grid;
    grid-template-columns: 3.5rem 3.4rem minmax(0, 1fr);
    gap: 1.2rem;
    padding: clamp(1.7rem, 3vw, 2.5rem) 0;
    border-bottom: 1px solid rgba(148, 163, 184, 0.16);
    transition: padding 220ms ease, background 220ms ease;
  }

  .service-row:hover {
    padding-right: 1rem;
    padding-left: 1rem;
    background: linear-gradient(90deg, rgba(34, 197, 94, 0.055), transparent);
  }

  .service-index {
    padding-top: 0.55rem;
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
  }

  .service-icon {
    display: grid;
    width: 3.4rem;
    height: 3.4rem;
    place-items: center;
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 1rem;
    color: var(--color-primary-light);
    background: linear-gradient(145deg, rgba(34, 197, 94, 0.12), rgba(59, 130, 246, 0.04));
  }

  .service-icon svg {
    width: 1.45rem;
    height: 1.45rem;
    stroke: currentColor;
    stroke-width: 1.55;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .service-content h3 {
    margin: 0;
    font-size: clamp(1.35rem, 2vw, 1.9rem);
    line-height: 1.08;
    letter-spacing: -0.035em;
  }

  .service-content > p {
    max-width: 43rem;
    margin: 0.75rem 0 0;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  .service-output {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.15rem;
    color: var(--color-primary-light);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
  }

  .service-output svg {
    width: 1rem;
    height: 1rem;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media (max-width: 980px) {
    .section-intro,
    .services-layout {
      grid-template-columns: 1fr;
    }

    .section-intro {
      gap: 1.6rem;
    }

    .section-intro > p {
      max-width: 45rem;
    }

    .services-photo {
      min-height: 500px;
    }
  }

  @media (max-width: 640px) {
    .section-shell {
      width: min(100% - 1.25rem, 1380px);
    }

    h2 span {
      display: block;
      margin-left: 0;
    }

    .services-photo {
      min-height: 420px;
      border-radius: 1.25rem;
    }

    .service-row {
      grid-template-columns: 2.4rem minmax(0, 1fr);
      gap: 0.8rem;
    }

    .service-icon {
      grid-column: 1;
      grid-row: 2;
      width: 2.4rem;
      height: 2.4rem;
      border-radius: 0.75rem;
    }

    .service-icon svg {
      width: 1.1rem;
      height: 1.1rem;
    }

    .service-content {
      grid-column: 2;
      grid-row: 1 / span 2;
    }
  }
</style>
