---
import Button from './Button.astro';
import LanguageSelector from './LanguageSelector.astro';

interface Props {
  lang: 'es' | 'en';
  nav: {
    logo: string;
    links: { label: string; href: string }[];
    cta: string;
    ctaHref: string;
    menuLabel: string;
    closeLabel: string;
  };
}

const { lang, nav } = Astro.props;
---

<header id="navbar" class="navbar">
  <nav class="nav-rail" aria-label={nav.logo}>
    <a href={`/${lang}/`} class="brand-link" aria-label={nav.logo}>
      <img
        src="/images/innovaai-logo-full.webp"
        alt=""
        width="576"
        height="220"
      />
    </a>

    <div class="desktop-links">
      {nav.links.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </div>

    <div class="desktop-actions">
      <LanguageSelector currentLang={lang} />
      <Button variant="primary" size="sm" href={nav.ctaHref}>
        {nav.cta}
      </Button>
    </div>

    <button
      id="mobile-toggle"
      class="mobile-toggle"
      type="button"
      aria-label={nav.menuLabel}
      aria-expanded="false"
      data-open-label={nav.closeLabel}
      data-closed-label={nav.menuLabel}
    >
      <span></span>
      <span></span>
    </button>
  </nav>

  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <div class="mobile-menu-inner">
      <div class="mobile-links">
        {nav.links.map((link, index) => (
          <a href={link.href} class="mobile-link">
            <span>0{index + 1}</span>
            {link.label}
          </a>
        ))}
      </div>

      <div class="mobile-actions">
        <LanguageSelector currentLang={lang} />
        <Button variant="primary" size="lg" href={nav.ctaHref} class="mobile-cta">
          {nav.cta}
        </Button>
      </div>
    </div>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar');
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');

  if (navbar && toggle && menu) {
    let isOpen = false;

    const syncScroll = () => {
      navbar.classList.toggle('is-scrolled', window.scrollY > 28);
    };

    const setMenu = (open: boolean) => {
      isOpen = open;
      navbar.classList.toggle('menu-open', open);
      menu.setAttribute('aria-hidden', String(!open));
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute(
        'aria-label',
        open
          ? toggle.dataset.openLabel || ''
          : toggle.dataset.closedLabel || '',
      );
      document.body.classList.toggle('menu-lock', open);
    };

    syncScroll();
    window.addEventListener('scroll', syncScroll, { passive: true });
    window.addEventListener('pageshow', syncScroll);
    toggle.addEventListener('click', () => setMenu(!isOpen));

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setMenu(false));
    });

    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && isOpen) {
        setMenu(false);
        toggle.focus();
      }
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768 && isOpen) setMenu(false);
    });
  }
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    right: 0;
    left: 0;
    z-index: 60;
    padding: 0.9rem 1rem 0;
    pointer-events: none;
  }

  .nav-rail {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    width: min(100%, 1380px);
    min-height: 68px;
    margin: 0 auto;
    padding: 0.55rem 0.65rem 0.55rem 1rem;
    border: 1px solid transparent;
    border-radius: 1rem;
    pointer-events: auto;
    transition:
      background 220ms ease,
      border-color 220ms ease,
      box-shadow 220ms ease,
      backdrop-filter 220ms ease;
  }

  .is-scrolled .nav-rail,
  .menu-open .nav-rail {
    border-color: rgba(148, 163, 184, 0.15);
    background: rgba(5, 12, 22, 0.84);
    box-shadow: 0 18px 55px rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(20px) saturate(130%);
  }

  .brand-link {
    display: inline-flex;
    width: max-content;
    align-items: center;
    padding: 0.3rem 0.5rem;
    border: 1px solid rgba(148, 163, 184, 0.12);
    border-radius: 0.65rem;
    background: #020918;
  }

  .brand-link img {
    display: block;
    width: auto;
    height: 1.7rem;
    object-fit: contain;
    transition: transform 180ms ease;
  }

  .brand-link:hover img {
    transform: translateY(-1px);
  }

  .desktop-links {
    display: flex;
    align-items: center;
    gap: clamp(1.4rem, 2.7vw, 2.7rem);
  }

  .desktop-links a {
    position: relative;
    padding: 0.75rem 0;
    color: var(--color-text-secondary);
    font-size: 0.82rem;
    font-weight: 550;
    transition: color 180ms ease;
  }

  .desktop-links a::after {
    content: '';
    position: absolute;
    right: 0;
    bottom: 0.45rem;
    left: 0;
    height: 1px;
    background: var(--color-primary-light);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 220ms ease;
  }

  .desktop-links a:hover {
    color: var(--color-text-primary);
  }

  .desktop-links a:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .desktop-actions {
    display: flex;
    justify-self: end;
    align-items: center;
    gap: 0.55rem;
  }

  .mobile-toggle,
  .mobile-menu {
    display: none;
  }

  @media (max-width: 900px) {
    .desktop-links {
      gap: 1.25rem;
    }
  }

  @media (max-width: 767px) {
    .navbar {
      padding: 0.6rem 0.625rem 0;
    }

    .nav-rail {
      grid-template-columns: 1fr auto;
      min-height: 62px;
      padding: 0.45rem 0.55rem 0.45rem 0.8rem;
    }

    .desktop-links,
    .desktop-actions {
      display: none;
    }

    .brand-link img {
      height: 1.6rem;
    }

    .mobile-toggle {
      position: relative;
      display: grid;
      width: 46px;
      height: 46px;
      place-items: center;
      border: 1px solid rgba(148, 163, 184, 0.14);
      border-radius: 0.8rem;
      color: var(--color-text-primary);
      background: rgba(255, 255, 255, 0.025);
    }

    .mobile-toggle span {
      position: absolute;
      width: 1.35rem;
      height: 1px;
      background: currentColor;
      transition: transform 220ms ease;
    }

    .mobile-toggle span:first-child {
      transform: translateY(-4px);
    }

    .mobile-toggle span:last-child {
      transform: translateY(4px);
    }

    .menu-open .mobile-toggle span:first-child {
      transform: rotate(45deg);
    }

    .menu-open .mobile-toggle span:last-child {
      transform: rotate(-45deg);
    }

    .mobile-menu {
      position: fixed;
      inset: 0;
      z-index: -1;
      display: block;
      padding: 6.2rem 0.625rem 0.625rem;
      pointer-events: none;
      opacity: 0;
      visibility: hidden;
      transition: opacity 220ms ease, visibility 220ms ease;
    }

    .mobile-menu::before {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(4, 10, 18, 0.96);
      backdrop-filter: blur(24px);
    }

    .menu-open .mobile-menu {
      pointer-events: auto;
      opacity: 1;
      visibility: visible;
    }

    .mobile-menu-inner {
      position: relative;
      display: flex;
      height: 100%;
      flex-direction: column;
      justify-content: space-between;
      overflow-y: auto;
      padding: 1.2rem 1rem 1.5rem;
      border: 1px solid rgba(148, 163, 184, 0.12);
      border-radius: 1.2rem;
      background:
        linear-gradient(145deg, rgba(34, 197, 94, 0.055), transparent 36%),
        rgba(7, 15, 27, 0.78);
    }

    .mobile-links {
      display: grid;
    }

    .mobile-link {
      display: grid;
      grid-template-columns: 2.5rem 1fr;
      gap: 0.75rem;
      align-items: center;
      padding: 1.15rem 0;
      border-bottom: 1px solid rgba(148, 163, 184, 0.12);
      color: var(--color-text-primary);
      font-family: var(--font-heading);
      font-size: clamp(1.65rem, 8vw, 2.5rem);
      font-weight: 650;
      letter-spacing: -0.045em;
    }

    .mobile-link span {
      color: var(--color-primary-light);
      font-family: var(--font-mono);
      font-size: 0.62rem;
      font-weight: 400;
      letter-spacing: 0.1em;
    }

    .mobile-actions {
      display: grid;
      gap: 0.75rem;
      padding-top: 2rem;
    }

    .mobile-actions :global(.language-switch),
    .mobile-actions :global(.mobile-cta) {
      width: 100%;
    }
  }
</style>
