---
interface Props {
  number: string;
  message: string;
  label?: string;
}

const { number, message, label = 'WhatsApp' } = Astro.props;
const waLink = `https://wa.me/${number}?text=${encodeURIComponent(message)}`;
---

<a
  id="whatsapp-float"
  href={waLink}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={label}
>
  <span class="whatsapp-label">{label}</span>
  <span class="whatsapp-icon">
    <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
    </svg>
  </span>
</a>

<style>
  #whatsapp-float {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 50;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.4rem;
    border: 1px solid rgba(37, 211, 102, 0.28);
    border-radius: 999px;
    color: #07110a;
    background: rgba(5, 14, 10, 0.82);
    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.32);
    backdrop-filter: blur(16px);
    opacity: 0;
    pointer-events: none;
    transform: translateY(12px);
    transition: opacity 350ms ease, transform 350ms ease;
  }

  .whatsapp-label {
    padding-left: 0.65rem;
    color: rgba(226, 232, 240, 0.82);
    font-size: 0.76rem;
    font-weight: 600;
  }

  .whatsapp-icon {
    display: grid;
    width: 2.65rem;
    height: 2.65rem;
    place-items: center;
    border-radius: 50%;
    color: #fff;
    background: #25d366;
    box-shadow: 0 0 24px rgba(37, 211, 102, 0.28);
    transition: transform 180ms ease;
  }

  #whatsapp-float:hover .whatsapp-icon {
    transform: scale(1.06);
  }

  svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  @media (max-width: 640px) {
    #whatsapp-float {
      right: 0.8rem;
      bottom: 0.8rem;
    }

    .whatsapp-label {
      display: none;
    }
  }
</style>

<script>
  const button = document.getElementById('whatsapp-float');
  if (button) {
    const syncVisibility = () => {
      const threshold = Math.min(560, window.innerHeight * 0.65);
      const isVisible = window.scrollY > threshold;

      button.style.opacity = isVisible ? '1' : '0';
      button.style.pointerEvents = isVisible ? 'auto' : 'none';
      button.style.transform = isVisible ? 'translateY(0)' : 'translateY(12px)';
    };

    syncVisibility();
    window.addEventListener('scroll', syncVisibility, { passive: true });
    window.addEventListener('pageshow', syncVisibility);
  }
</script>
