---
import ProductCard from './ProductCard.astro';

interface Props {
  section: {
    badge: string;
    titleBefore: string;
    titleAccent: string;
    subtitle: string;
  };
  products: {
    name: string;
    eyebrow: string;
    tagline: string;
    description: string;
    bullets: string[];
    meta: string[];
    color: 'dicta' | 'diariomed';
    cta: string;
    ctaHref: string;
    image: string;
    imageAlt: string;
    secondaryImage?: string;
    secondaryImageAlt?: string;
    tertiaryImage?: string;
    tertiaryImageAlt?: string;
    visualLabel: string;
  }[];
}

const { section, products } = Astro.props;
---

<section id="productos" class="products-section section-padding">
  <div class="section-shell">
    <header class="products-intro" data-animate="fade-up">
      <span class="section-kicker">{section.badge}</span>
      <h2>
        {section.titleBefore}
        <span class="gradient-text">{section.titleAccent}</span>
      </h2>
      <p>{section.subtitle}</p>
    </header>

    <div class="product-list">
      {products.map((product, index) => (
        <ProductCard product={product} reversed={index % 2 !== 0} />
      ))}
    </div>
  </div>
</section>

<style>
  .products-section {
    position: relative;
    overflow: hidden;
    border-top: 1px solid rgba(148, 163, 184, 0.09);
    border-bottom: 1px solid rgba(148, 163, 184, 0.09);
    background:
      radial-gradient(circle at 16% 20%, rgba(34, 197, 94, 0.055), transparent 24%),
      radial-gradient(circle at 88% 72%, rgba(59, 130, 246, 0.05), transparent 24%),
      rgba(8, 15, 27, 0.76);
  }

  .section-shell {
    width: min(100% - 2rem, 1380px);
    margin: 0 auto;
  }

  .products-intro {
    max-width: 920px;
    margin-bottom: clamp(4rem, 8vw, 7rem);
  }

  .section-kicker {
    display: block;
    margin-bottom: 1rem;
    color: var(--color-primary-light);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.16em;
  }

  h2 {
    margin: 0;
    font-size: clamp(2.65rem, 5.4vw, 5.6rem);
    line-height: 0.98;
    letter-spacing: -0.06em;
    text-wrap: balance;
  }

  h2 span {
    display: inline-block;
    margin-left: 0.12em;
  }

  .products-intro p {
    max-width: 690px;
    margin: 1.5rem 0 0;
    color: var(--color-text-secondary);
    font-size: clamp(1rem, 1.35vw, 1.17rem);
    line-height: 1.7;
  }

  .product-list {
    display: grid;
    gap: clamp(7rem, 14vw, 13rem);
  }

  @media (max-width: 640px) {
    .section-shell {
      width: min(100% - 1.25rem, 1380px);
    }

    h2 span {
      display: block;
      margin-left: 0;
    }

    .product-list {
      gap: 7rem;
    }
  }
</style>
