---
interface Props {
  class?: string;
  hover?: boolean;
}

const { class: className = '', hover = true } = Astro.props;
const hoverClasses = hover ? 'hover:-translate-y-1 hover:border-primary/30 hover:shadow-[0_0_30px_rgba(34,197,94,0.1)]' : '';
---

<div class={`glass rounded-2xl p-6 transition-all duration-300 ${hoverClasses} ${className}`}>
  <slot />
</div>
