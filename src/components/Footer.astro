---
interface Props {
  footer: {
    tagline: string;
    location: string;
    columns: { title: string; links: { label: string; href: string }[] }[];
    social: { label: string; href: string; icon: string }[];
    copyright: string;
    madeWith: string;
  };
  lang: 'es' | 'en';
}

const { footer, lang } = Astro.props;
---

<footer class="site-footer">
  <div class="footer-shell">
    <div class="footer-top">
      <div class="footer-brand">
        <a href={`/${lang}/`} aria-label="InnovaAI">
          <img
            src="/images/innovaai-logo-full.webp"
            alt=""
            width="576"
            height="220"
            loading="lazy"
          />
        </a>
        <p>{footer.tagline}</p>
        <span>{footer.location}</span>
      </div>

      <div class="footer-columns">
        {footer.columns.map((column) => (
          <div>
            <h2>{column.title}</h2>
            <ul>
              {column.links.map((link) => {
                const isExternal = /^https?:\/\//.test(link.href);
                return (
                  <li>
                    <a
                      href={link.href}
                      target={isExternal ? '_blank' : undefined}
                      rel={isExternal ? 'noopener noreferrer' : undefined}
                    >
                      {link.label}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="footer-bottom">
      <p>{footer.copyright}</p>
      <div class="footer-signoff">
        <span><i aria-hidden="true"></i>{footer.madeWith}</span>
        {footer.social.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={social.label}
            data-social={social.icon}
          >
            {social.icon === 'linkedin' && (
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V8.997h3.414v1.561h.048c.475-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.371 4.267 5.455v6.289h-.003ZM5.337 7.433a2.062 2.062 0 1 1 0-4.124 2.062 2.062 0 0 1 0 4.124ZM7.119 20.452H3.555V8.997h3.564v11.455ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003Z" />
              </svg>
            )}
            {social.icon === 'whatsapp' && (
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
              </svg>
            )}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: clamp(5rem, 9vw, 8rem) 0 2rem;
  }

  .footer-shell {
    width: min(100% - 2rem, 1380px);
    margin: 0 auto;
  }

  .footer-top {
    display: grid;
    grid-template-columns: minmax(280px, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(3rem, 8vw, 9rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .footer-brand a {
    display: inline-flex;
    padding: 0.45rem 0.65rem;
    border: 1px solid rgba(148, 163, 184, 0.12);
    border-radius: 0.75rem;
    background: #020918;
  }

  .footer-brand img {
    display: block;
    width: auto;
    height: 2.55rem;
  }

  .footer-brand p {
    max-width: 28rem;
    margin: 1.4rem 0 0;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .footer-brand > span {
    display: block;
    margin-top: 1.25rem;
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
  }

  .footer-columns {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
  }

  h2 {
    margin: 0 0 1.2rem;
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  ul {
    display: grid;
    gap: 0.85rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  li a {
    color: var(--color-text-secondary);
    font-size: 0.88rem;
    transition: color 180ms ease;
  }

  li a:hover {
    color: var(--color-primary-light);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(148, 163, 184, 0.11);
  }

  .footer-bottom > p {
    margin: 0;
    color: var(--color-text-tertiary);
    font-size: 0.72rem;
  }

  .footer-signoff {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer-signoff > span {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-tertiary);
    font-family: var(--font-mono);
    font-size: 0.61rem;
    letter-spacing: 0.07em;
  }

  .footer-signoff i {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: var(--color-primary-light);
    box-shadow: 0 0 11px var(--color-primary);
  }

  .footer-signoff a {
    display: grid;
    width: 2.2rem;
    height: 2.2rem;
    place-items: center;
    border: 1px solid rgba(148, 163, 184, 0.14);
    border-radius: 0.65rem;
    color: var(--color-text-secondary);
    background: rgba(255, 255, 255, 0.025);
    transition: color 180ms ease, border-color 180ms ease, transform 180ms ease;
  }

  .footer-signoff a:hover {
    transform: translateY(-2px);
  }

  .footer-signoff a[data-social='linkedin']:hover {
    color: #0a66c2;
    border-color: rgba(10, 102, 194, 0.4);
  }

  .footer-signoff a[data-social='whatsapp']:hover {
    color: #25d366;
    border-color: rgba(37, 211, 102, 0.35);
  }

  .footer-signoff svg {
    width: 1rem;
    height: 1rem;
  }

  @media (max-width: 820px) {
    .footer-top {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .footer-shell {
      width: min(100% - 1.25rem, 1380px);
    }

    .footer-columns {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .footer-bottom {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
