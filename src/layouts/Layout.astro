---
import '@fontsource/bricolage-grotesque/500.css';
import '@fontsource/bricolage-grotesque/600.css';
import '@fontsource/bricolage-grotesque/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: 'es' | 'en';
}

const { title, description, lang = 'es' } = Astro.props;
const altLang = lang === 'es' ? 'en' : 'es';
const currentPath = Astro.url.pathname;
const altPath = currentPath.replace(`/${lang}`, `/${altLang}`);
const canonicalURL = new URL(currentPath, Astro.site ?? 'https://innovaai-landing.onrender.com');
const altURL = new URL(altPath, Astro.site ?? 'https://innovaai-landing.onrender.com');
const defaultURL = new URL(currentPath.replace(`/${lang}`, '/es'), Astro.site ?? 'https://innovaai-landing.onrender.com');
const siteURL = new URL('/', Astro.site ?? 'https://innovaai-landing.onrender.com');
const logoURL = new URL('/images/innovaai-logo-full.png', siteURL);
const ogImageURL = new URL('/images/innovaai-og.jpg', siteURL);
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteURL.href}#organization`,
      name: 'InnovaAI',
      url: siteURL.href,
      logo: logoURL.href,
      image: ogImageURL.href,
      description:
        lang === 'es'
          ? 'Consultoría y productos de inteligencia artificial aplicada para empresas en Latinoamérica.'
          : 'Applied artificial intelligence consulting and AI products for companies in Latin America.',
      areaServed: ['Bolivia', 'Latin America'],
      contactPoint: {
        '@type': 'ContactPoint',
        telephone: '+59172004767',
        contactType: 'sales',
        availableLanguage: ['Spanish', 'English'],
      },
      knowsAbout: [
        'AI consulting',
        'business automation',
        'knowledge management',
        'team adoption',
        'voice dictation',
        'dental clinic software',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteURL.href}#website`,
      name: 'InnovaAI',
      url: siteURL.href,
      publisher: { '@id': `${siteURL.href}#organization` },
      inLanguage: ['es', 'en'],
    },
    {
      '@type': 'WebPage',
      '@id': `${canonicalURL.href}#webpage`,
      url: canonicalURL.href,
      name: title,
      description,
      isPartOf: { '@id': `${siteURL.href}#website` },
      about: { '@id': `${siteURL.href}#organization` },
      inLanguage: lang,
    },
    {
      '@type': 'Service',
      '@id': `${siteURL.href}#applied-ai-consulting`,
      name: lang === 'es' ? 'Consultoría de IA aplicada' : 'Applied AI consulting',
      provider: { '@id': `${siteURL.href}#organization` },
      areaServed: ['Bolivia', 'Latin America'],
      serviceType: lang === 'es' ? 'Consultoría de inteligencia artificial' : 'Artificial intelligence consulting',
      description:
        lang === 'es'
          ? 'Diagnóstico, prototipado e implementación de soluciones de IA con procesos y datos reales.'
          : 'Diagnostic, prototyping, and implementation of AI solutions with real processes and data.',
    },
  ],
};
---

<!doctype html>
<html lang={lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#060D18" />
    <meta name="color-scheme" content="dark" />

    <link rel="icon" type="image/png" sizes="32x32" href="/images/innovaai-logo-mark-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/images/innovaai-logo-mark-192.png" />
    <link rel="apple-touch-icon" href="/images/innovaai-logo-mark-192.png" />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="alternate" hreflang={lang} href={canonicalURL.href} />
    <link rel="alternate" hreflang={altLang} href={altURL.href} />
    <link rel="alternate" hreflang="x-default" href={defaultURL.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="InnovaAI" />
    <meta property="og:locale" content={lang === 'es' ? 'es_LA' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'es' ? 'en_US' : 'es_LA'} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content={lang === 'es'
        ? 'InnovaAI — IA aplicada a negocios en Latinoamérica'
        : 'InnovaAI — Applied AI for businesses in Latin America'}
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />
    <meta
      name="twitter:image:alt"
      content={lang === 'es'
        ? 'InnovaAI — IA aplicada a negocios en Latinoamérica'
        : 'InnovaAI — Applied AI for businesses in Latin America'}
    />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <title>{title}</title>
  </head>
  <body class="bg-bg-primary text-text-primary antialiased">
    <slot />
  </body>
</html>
