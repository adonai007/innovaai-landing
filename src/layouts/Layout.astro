---
import '@fontsource/bricolage-grotesque/500.css';
import '@fontsource/bricolage-grotesque/600.css';
import '@fontsource/bricolage-grotesque/700.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: 'es' | 'en';
  organizationDescription: string;
  ogImageAlt: string;
  structuredData?: Record<string, unknown>[];
  mainEntityId?: string;
}

const {
  title,
  description,
  lang = 'es',
  organizationDescription,
  ogImageAlt,
  structuredData = [],
  mainEntityId,
} = Astro.props;
const altLang = lang === 'es' ? 'en' : 'es';
const currentPath = Astro.url.pathname;
const altPath = currentPath.replace(`/${lang}`, `/${altLang}`);
const canonicalURL = new URL(currentPath, Astro.site ?? 'https://innovai.click');
const altURL = new URL(altPath, Astro.site ?? 'https://innovai.click');
const defaultURL = new URL(currentPath.replace(`/${lang}`, '/es'), Astro.site ?? 'https://innovai.click');
const siteURL = new URL('/', Astro.site ?? 'https://innovai.click');
const logoURL = new URL('/images/innovaai-logo-full.png', siteURL);
const ogImageURL = new URL('/images/innovaai-og.jpg', siteURL);
const organizationId = `${siteURL.href}#organization`;
const websiteId = `${siteURL.href}#website`;
const webpageId = `${canonicalURL.href}#webpage`;
const pageEntityId = mainEntityId ?? organizationId;
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': organizationId,
      name: 'InnovaAI',
      alternateName: 'Innova AI',
      legalName: 'InnovaAI SRL',
      url: siteURL.href,
      logo: {
        '@type': 'ImageObject',
        url: logoURL.href,
        contentUrl: logoURL.href,
        width: 576,
        height: 220,
      },
      image: {
        '@type': 'ImageObject',
        url: ogImageURL.href,
        contentUrl: ogImageURL.href,
        width: 1200,
        height: 630,
      },
      description: organizationDescription,
      sameAs: ['https://www.linkedin.com/company/innovai-click/'],
      address: {
        '@type': 'PostalAddress',
        addressCountry: 'BO',
      },
      areaServed: ['Bolivia', 'Latin America'],
      founder: {
        '@type': 'Person',
        name: 'Adonai Callejas',
      },
      contactPoint: {
        '@type': 'ContactPoint',
        telephone: '+59172004767',
        contactType: 'sales',
        availableLanguage: ['Spanish', 'English'],
      },
      knowsLanguage: ['Spanish', 'English'],
      knowsAbout: [
        'AI consulting',
        'business automation',
        'knowledge management',
        'team adoption',
        'voice dictation',
        'dental clinic software',
      ],
    },
    {
      '@type': 'WebSite',
      '@id': websiteId,
      name: 'InnovaAI',
      alternateName: 'Innova AI',
      url: siteURL.href,
      publisher: { '@id': organizationId },
      inLanguage: ['es', 'en'],
    },
    {
      '@type': 'WebPage',
      '@id': webpageId,
      url: canonicalURL.href,
      name: title,
      description,
      isPartOf: { '@id': websiteId },
      about: { '@id': pageEntityId },
      mainEntity: { '@id': pageEntityId },
      primaryImageOfPage: {
        '@type': 'ImageObject',
        url: ogImageURL.href,
        contentUrl: ogImageURL.href,
        width: 1200,
        height: 630,
      },
      inLanguage: lang,
    },
    ...structuredData,
  ],
};
---

<!doctype html>
<html lang={lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta
      name="robots"
      content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
    />
    <meta name="author" content="InnovaAI" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#060D18" />
    <meta name="color-scheme" content="dark" />

    <link rel="icon" type="image/png" sizes="32x32" href="/images/innovaai-logo-mark-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/images/innovaai-logo-mark-192.png" />
    <link rel="apple-touch-icon" href="/images/innovaai-logo-mark-192.png" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="alternate" hreflang={lang} href={canonicalURL.href} />
    <link rel="alternate" hreflang={altLang} href={altURL.href} />
    <link rel="alternate" hreflang="x-default" href={defaultURL.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="InnovaAI" />
    <meta property="og:locale" content={lang === 'es' ? 'es_BO' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'es' ? 'en_US' : 'es_BO'} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:image:secure_url" content={ogImageURL.href} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content={ogImageAlt}
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />
    <meta
      name="twitter:image:alt"
      content={ogImageAlt}
    />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <title>{title}</title>
  </head>
  <body class="bg-bg-primary text-text-primary antialiased">
    <slot />
  </body>
</html>
