---
import Layout from '../../../layouts/Layout.astro';
import DmNavbar from '../../../components/diariomed/DmNavbar.astro';
import DmHero from '../../../components/diariomed/DmHero.astro';
import ParticleBackground from '../../../components/ParticleBackground.astro';
import DmProblem from '../../../components/diariomed/DmProblem.astro';
import DmSolution from '../../../components/diariomed/DmSolution.astro';
import DmHowItWorks from '../../../components/diariomed/DmHowItWorks.astro';
import DmFeatures from '../../../components/diariomed/DmFeatures.astro';
import DmResults from '../../../components/diariomed/DmResults.astro';
import DmPricing from '../../../components/diariomed/DmPricing.astro';
import DmSecurity from '../../../components/diariomed/DmSecurity.astro';
import DmComparison from '../../../components/diariomed/DmComparison.astro';
import DmFaq from '../../../components/diariomed/DmFaq.astro';
import DmCtaFinal from '../../../components/diariomed/DmCtaFinal.astro';
import WhatsAppButton from '../../../components/WhatsAppButton.astro';
import Footer from '../../../components/Footer.astro';

import {
  dmNavigation,
  dmHero,
  dmProblem,
  dmSolution,
  dmHowItWorks,
  dmFeatures,
  dmResults,
  dmPricing,
  dmSecurity,
  dmComparison,
  dmFaq,
  dmCtaFinal,
  dmFooter,
} from '../../../data/en/diariomed';
import { seo } from '../../../data/en/seo';

const siteURL = new URL('/', Astro.site ?? 'https://innovai.click');
const pageURL = new URL('/en/dentimed/', siteURL);
const softwareId = `${pageURL.href}#software`;
const structuredData = [
  {
    '@type': ['SoftwareApplication', 'WebApplication'],
    '@id': softwareId,
    name: dmNavigation.logo,
    url: pageURL.href,
    description: seo.dentimed.description,
    applicationCategory: 'HealthApplication',
    operatingSystem: 'Web',
    softwareRequirements: seo.dentimed.softwareRequirements,
    provider: { '@id': `${siteURL.href}#organization` },
    audience: {
      '@type': 'Audience',
      audienceType: seo.dentimed.audience,
    },
    featureList: dmFeatures.cards.map(
      (feature) => `${feature.title}: ${feature.description}`,
    ),
    offers: dmPricing.plans
      .filter((plan) => plan.price > 0)
      .map((plan) => ({
        '@type': 'Offer',
        name: plan.name,
        price: plan.price,
        priceCurrency: 'USD',
        url: `${pageURL.href}#precios`,
      })),
  },
  {
    '@type': 'FAQPage',
    '@id': `${pageURL.href}#faq-schema`,
    mainEntity: dmFaq.items.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  },
] satisfies Record<string, unknown>[];
---

<Layout
  title={seo.dentimed.title}
  description={seo.dentimed.description}
  lang="en"
  organizationDescription={seo.organizationDescription}
  ogImageAlt={seo.ogImageAlt}
  structuredData={structuredData}
  mainEntityId={softwareId}
>
  <DmNavbar nav={dmNavigation} lang="en" />
  <main>
    <DmHero hero={dmHero}>
      <ParticleBackground slot="default" />
    </DmHero>
    <DmProblem section={dmProblem} />
    <DmSolution section={dmSolution} />
    <DmHowItWorks section={dmHowItWorks} />
    <DmFeatures section={dmFeatures} />
    <DmResults section={dmResults} />
    <DmPricing section={dmPricing} />
    <DmSecurity section={dmSecurity} />
    <DmComparison section={dmComparison} />
    <DmFaq section={dmFaq} />
    <DmCtaFinal cta={dmCtaFinal} />
  </main>
  <Footer footer={dmFooter} lang="en" />
  <WhatsAppButton number={dmCtaFinal.whatsappNumber} message={dmCtaFinal.whatsappMessage} />

  <script>
    import '../../../scripts/animations';
  </script>
</Layout>
