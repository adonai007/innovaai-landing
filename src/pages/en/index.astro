---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.astro';
import TrustBar from '../../components/TrustBar.astro';
import Services from '../../components/Services.astro';
import Products from '../../components/Products.astro';
import Process from '../../components/Process.astro';
import Stats from '../../components/Stats.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import Footer from '../../components/Footer.astro';

import { navigation } from '../../data/en/navigation';
import { hero } from '../../data/en/hero';
import { trustBar } from '../../data/en/trust';
import { servicesSection, services } from '../../data/en/services';
import { productsSection, products } from '../../data/en/products';
import { processSection, steps } from '../../data/en/process-steps';
import { whySection, differentiators } from '../../data/en/stats';
import { faqSection, faqItems } from '../../data/en/faq';
import { cta, footer } from '../../data/en/cta';
import { seo } from '../../data/en/seo';

const siteURL = new URL('/', Astro.site ?? 'https://innovai.click');
const pageURL = new URL('/en/', siteURL);
const serviceId = `${pageURL.href}#applied-ai-consulting`;
const structuredData = [
  {
    '@type': 'Service',
    '@id': serviceId,
    name: seo.home.serviceName,
    serviceType: seo.home.serviceType,
    description: seo.home.serviceDescription,
    url: pageURL.href,
    provider: { '@id': `${siteURL.href}#organization` },
    areaServed: ['Bolivia', 'Latin America'],
    audience: {
      '@type': 'BusinessAudience',
      audienceType: seo.home.audience,
    },
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: seo.home.serviceName,
      itemListElement: services.map((service) => ({
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: service.title,
          description: service.description,
        },
      })),
    },
  },
  {
    '@type': 'FAQPage',
    '@id': `${pageURL.href}#faq`,
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  },
] satisfies Record<string, unknown>[];
---

<Layout
  title={seo.home.title}
  description={seo.home.description}
  lang="en"
  organizationDescription={seo.organizationDescription}
  ogImageAlt={seo.ogImageAlt}
  structuredData={structuredData}
  mainEntityId={serviceId}
>
  <Navbar lang="en" nav={navigation} />
  <main>
    <Hero hero={hero} />
    <TrustBar trust={trustBar} />
    <Services section={servicesSection} services={services} />
    <Products section={productsSection} products={products} />
    <Process section={processSection} steps={steps} />
    <Stats section={whySection} differentiators={differentiators} />
    <FAQ section={faqSection} items={faqItems} />
    <CTASection cta={cta} />
  </main>
  <Footer footer={footer} lang="en" />
  <WhatsAppButton
    number={cta.whatsappNumber}
    message={cta.whatsappMessage}
    label={cta.ctaPrimary}
  />

  <script>
    import '../../scripts/animations';
  </script>
</Layout>
