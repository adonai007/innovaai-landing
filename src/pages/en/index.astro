---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.astro';
import TrustBar from '../../components/TrustBar.astro';
import Services from '../../components/Services.astro';
import Products from '../../components/Products.astro';
import Process from '../../components/Process.astro';
import Stats from '../../components/Stats.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import Footer from '../../components/Footer.astro';

import { navigation } from '../../data/en/navigation';
import { hero } from '../../data/en/hero';
import { trustBar } from '../../data/en/trust';
import { servicesSection, services } from '../../data/en/services';
import { productsSection, products } from '../../data/en/products';
import { processSection, steps } from '../../data/en/process-steps';
import { whySection, differentiators } from '../../data/en/stats';
import { faqSection, faqItems } from '../../data/en/faq';
import { cta, footer } from '../../data/en/cta';
---

<Layout
  title="InnovaAI — Applied AI for Companies in Latin America"
  description="We diagnose, prototype, and implement AI solutions with your real processes and data. Applied AI consulting and products from Bolivia."
  lang="en"
>
  <Navbar lang="en" nav={navigation} />
  <main>
    <Hero hero={hero} />
    <TrustBar trust={trustBar} />
    <Services section={servicesSection} services={services} />
    <Products section={productsSection} products={products} />
    <Process section={processSection} steps={steps} />
    <Stats section={whySection} differentiators={differentiators} />
    <FAQ section={faqSection} items={faqItems} />
    <CTASection cta={cta} />
  </main>
  <Footer footer={footer} lang="en" />
  <WhatsAppButton
    number={cta.whatsappNumber}
    message={cta.whatsappMessage}
    label={cta.ctaPrimary}
  />

  <script>
    import '../../scripts/animations';
  </script>
</Layout>
