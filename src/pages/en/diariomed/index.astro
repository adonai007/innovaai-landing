---
const targetPath = '/en/dentimed/';
const target = new URL(targetPath, Astro.site ?? 'https://innovai.click').href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex, follow" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>DentiMed</title>
    <script is:inline>
      window.location.replace('/en/dentimed/');
    </script>
  </head>
  <body>
    <a href={target}>Go to DentiMed</a>
  </body>
</html>
