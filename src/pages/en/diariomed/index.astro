---
const target = '/en/dentimed/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>DentiMed</title>
    <script is:inline>
      window.location.replace('/en/dentimed/');
    </script>
  </head>
  <body>
    <a href={target}>Go to DentiMed</a>
  </body>
</html>
