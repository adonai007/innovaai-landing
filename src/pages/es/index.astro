---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.astro';
import TrustBar from '../../components/TrustBar.astro';
import Services from '../../components/Services.astro';
import Products from '../../components/Products.astro';
import Process from '../../components/Process.astro';
import Stats from '../../components/Stats.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import Footer from '../../components/Footer.astro';

import { navigation } from '../../data/es/navigation';
import { hero } from '../../data/es/hero';
import { trustBar } from '../../data/es/trust';
import { servicesSection, services } from '../../data/es/services';
import { productsSection, products } from '../../data/es/products';
import { processSection, steps } from '../../data/es/process-steps';
import { whySection, differentiators } from '../../data/es/stats';
import { faqSection, faqItems } from '../../data/es/faq';
import { cta, footer } from '../../data/es/cta';
---

<Layout
  title="InnovaAI — IA Aplicada para Empresas en Latinoamérica"
  description="Diagnosticamos, prototipamos e implementamos soluciones de IA con tus procesos y datos reales. Consultoría y productos de IA aplicada desde Bolivia."
  lang="es"
>
  <Navbar lang="es" nav={navigation} />
  <main>
    <Hero hero={hero} />
    <TrustBar trust={trustBar} />
    <Services section={servicesSection} services={services} />
    <Products section={productsSection} products={products} />
    <Process section={processSection} steps={steps} />
    <Stats section={whySection} differentiators={differentiators} />
    <FAQ section={faqSection} items={faqItems} />
    <CTASection cta={cta} />
  </main>
  <Footer footer={footer} lang="es" />
  <WhatsAppButton
    number={cta.whatsappNumber}
    message={cta.whatsappMessage}
    label={cta.ctaPrimary}
  />

  <script>
    import '../../scripts/animations';
  </script>
</Layout>
